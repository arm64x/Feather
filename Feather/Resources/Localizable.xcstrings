    "Enter the password associated with the private key. Leave it blank if theres no password required." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zadejte heslo spojené s privátním klíčem. Když žádné není potřeba, nezadávejte ho."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib das Passwort ein, das mit dem privaten Schlüssel verknüpft ist. Lasse es leer, wenn kein Passwort erforderlich ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter the password associated with the private key. Leave it blank if theres no password required."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Introduzca la contraseña asociada a la llave privada, déjalo en blanco si una contraseña no es necesaria."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entrez le mot de passe associé à la clé privée, laissez vide si aucun mot de passe n'est requis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Введите пароль, связанный с закрытым ключом, оставьте поле пустым, если пароль не требуется."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhập mật khẩu của chứng chỉ. Để trống nếu không yêu cầu mật khẩu."
